% 矩阵/行列式的行、列划线(划线方式:固定两点后在连线)
\newcommand{\ccr}[1]{\makecell{{\color{#1}\rule{1cm}{1cm}}}}
\newcommand{\MyTikzmark}[2]{%
     \tikz[overlay,remember picture,baseline] \node [anchor=base] (#1) {$#2$};%
}
\newcommand{\DrawVLine}[3][]{%
  \begin{tikzpicture}[overlay,remember picture]
    \draw[shorten <=0.3ex, #1] (#2.north) -- (#3.south);
  \end{tikzpicture}
}
\newcommand{\DrawHLine}[3][]{%
  \begin{tikzpicture}[overlay,remember picture]
    \draw[shorten <=0.2em, #1] (#2.west) -- (#3.east);
  \end{tikzpicture}
}
\newcommand\ddfrac[2]{\frac{\displaystyle #1}{\displaystyle #2}}

% “例” environment with counter
\newcounter{examples}[chapter]
\setcounter{examples}{0}
\renewcommand{\theexamples}{\thechapter.\arabic{examples}}
\newenvironment{examples}[1][]{
  \refstepcounter{examples}
  \par\noindent\textbf{\color{main}{例} \theexamples #1 }\rmfamily}{
  \par\ignorespacesafterend}

