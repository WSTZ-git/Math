\newunicodechar{；}{;}
\newunicodechar{！}{!}
\newunicodechar{（}{(}
\newunicodechar{）}{)}

% 自定义颜色
\definecolor{togglecolor}{RGB}{0,102,204}% bright blue

% 显示/隐藏proof、solution、note设置
% 全局总开关定义
\newcommand{\AllToggle}{%
  \switchocg{global}{\textcolor{togglecolor}{\bfseries Show/Hide}}%
}
\AtBeginDocument{%
  \begin{ocg}{全局控制}{global}{off}\end{ocg}% 全局默认关闭
}

% 自动计数器
\newcounter{ocgcount}

% 证明和解中的内容如果开头不是带序号的环境则在开头空一行，否则不空行
% 证明环境 proof
\renewenvironment{proof}{%
  \stepcounter{ocgcount}%
  \par\noindent
  \textbf{\color{second}\proofname\;}\color{black!90}\cfs\quad
  \begin{ocg}{pr\theocgcount}{pr\theocgcount}{on}%
    \begin{ocg}{}{global}{on}%
      \switchocg{pr\theocgcount}{\textcolor{togglecolor}{Show/Hide Proof}}%
      \par\nobreak
      \noindent\ignorespaces
}{%
      \par\nobreak
      \noindent\hfill$\Box$\quad
    \end{ocg}%
  \end{ocg}%
  \par
}

% 证明和解中的内容如果开头不是带序号的环境则在开头空一行，否则不空行
% 解答环境 solution
\renewenvironment{solution}{%
  \stepcounter{ocgcount}%
  \par\noindent
  \textbf{\color{main}\solutionname} \citshape\quad
  \begin{ocg}{sol\theocgcount}{sol\theocgcount}{on}%
    \begin{ocg}{}{global}{on}%
      \switchocg{sol\theocgcount}{\textcolor{togglecolor}{Show/Hide Solution}}%
      \par\nobreak
      \noindent\ignorespaces
}{%
      \par\nobreak
      \noindent\hfill$\Box$\quad
    \end{ocg}%
  \end{ocg}%
  \par
}

% 笔记环境 note
\renewenvironment{note}{%
  \stepcounter{ocgcount}%
  \par\noindent
  \makebox[-3pt][r]{\scriptsize\color{red!90}\textdbend\quad}
  \textbf{\color{second}\notename} \citshape\quad
  \begin{ocg}{nt\theocgcount}{nt\theocgcount}{on}%
    \begin{ocg}{}{global}{on}%
      \switchocg{nt\theocgcount}{\textcolor{togglecolor}{Show/Hide Note}}%
      \par\nobreak
      \noindent\ignorespaces
}{%
    \leavevmode\end{ocg}%
  \end{ocg}%
  \par
}

