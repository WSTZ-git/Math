% R代码样式配置，模拟PPT中的深色背景风格
\lstset{
    language=R,
    basicstyle=\ttfamily\small\color{white},
    keywordstyle=\color{cyan},
    commentstyle=\color{green!60!black},
    stringstyle=\color{yellow},
    frame=single,
    breaklines=true,
    numbers=left,
    numberstyle=\tiny\color{gray},
    backgroundcolor=\color{black!85},
    rulecolor=\color{gray!30},
    showstringspaces=false
}
\let\plain\relax% 清除\plain的旧定义

% ========== Beamer 兼容性设置 ==========
% 针对 Beamer 类定制 enumitem 行为，并保留默认项目符号
\makeatletter
\@ifclassloaded{beamer}{
  % 1. 设置列表全局参数：紧凑、左对齐
  \setlist{nosep, left=0pt, labelindent=0pt}
  % 2. 一级枚举标签：大写字母加圆点，使用罗马字体
  \setlist[enumerate,1]{label=\Alph*., font=\rmfamily}
  % 3. 二级枚举标签（若有）：小写字母加括号，使用罗马字体（可自定义）
  \setlist[enumerate,2]{label=(\alph*), font=\rmfamily}
  % 4. 保留 Beamer 原有的项目符号样式（itemize）
  \setbeamertemplate{itemize item}[circle]
  \setbeamertemplate{itemize subitem}[square]
  \setbeamertemplate{itemize subsubitem}[triangle]
}{}
\makeatother

% ========== bm 包内存优化 ==========
% beamer 中 \boldsymbol 消耗大量内存，用 \mathbf 替代
\AtBeginDocument{
  \let\boldsymbol\mathbf
}

% ========== 其他格式设置 ==========
\allowdisplaybreaks[4] %允许公式跨页显示
\everymath{\displaystyle} % 使全文的行内公式都显示成行间公式
% 使用\textstyle可恢复行内公式,例如${\textstyle \sum_{i=1}^nx_i}$

\setlength{\emergencystretch}{3em}% 允许行尾有更多伸展空间，防止溢出
\sloppy% 提高换行容忍度（不强行拉宽，优先换行）

% 全角符号转换为半角符号设置
\newunicodechar{（}{(}
\newunicodechar{）}{)}
