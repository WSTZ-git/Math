\ProvidesPackage{mystyle-PPT}

\usepackage{ctex}
\usepackage{amsmath,amssymb}
\usepackage{cases}% 实现大括号内多编号 一定要放在\usepackage{amsmath}之后
% beamer 已内置 enumerate 处理，enumitem 会导致冲突
% \usepackage{enumitem}% 插入有序列表
\usepackage{rotating}% 符号旋转
\usepackage{graphicx}% 插入图片
\usepackage{epstopdf}% 插入图片pdf
\usepackage{float}% 调整图片位置 固定图片位置[H]
\usepackage{bm}
\usepackage{soul}% 提供丰富多样的下划线,\soulcolor{red}\ul{红色下划线的文本}
\usepackage{xeCJKfntef}% 下划线可换行
\usepackage{multirow}
\usepackage{bigdelim}
\usepackage{tikz}% 绘制图表
\usepackage{tikz-cd}% 绘制图表
\usepackage{array}% 表格
\usepackage{blkarray}% 实现对矩阵行列加编号
\usepackage{tabularray}% 绘制表格
\usepackage{amsfonts}% 加目录
\usepackage{extarrows} % 自动适应等号长度并在等号上/下加文字
\usepackage{pifont}%  圆圈数字、圆圈序号
\let\widering\relax% 清除\widering的旧定义(因为yhmath宏包中已经定义了\widering这个命令,否则会与pifont包冲突)
\usepackage{yhmath}% 用\wideparen{}画出来的圆弧上标更美观
\usepackage{cprotect}% 允许在“移动参数”（moving arguments，例如 \section、\caption、\footnote、\item 等会被写入辅助文件或作为标题使用的命令）的参数中使用易碎命令或 verbatim 类内容（如 \verb、\lstinline、\url 等），避免出现 “You can't use \verb in a moving argument.” 的错误。
\usepackage{fancyhdr}% 添加 fancyhdr 宏包用于页眉页脚控制
\usepackage{etoolbox}% 用于条件判断
\usepackage{listings}% 代码高亮包（展示R代码）
\usepackage{xcolor}
% R代码样式配置，模拟PPT中的深色背景风格
\lstset{
    language=R,
    basicstyle=\ttfamily\small\color{white},
    keywordstyle=\color{cyan},
    commentstyle=\color{green!60!black},
    stringstyle=\color{yellow},
    frame=single,
    breaklines=true,
    numbers=left,
    numberstyle=\tiny\color{gray},
    backgroundcolor=\color{black!85},
    rulecolor=\color{gray!30},
    showstringspaces=false
}
\let\plain\relax% 清除\plain的旧定义

% ========== beamer 兼容性修复 ==========
% 防止 enumitem 与 beamer 的 \labelenumi 冲突导致无限递归
\makeatletter
\@ifpackageloaded{beamer}{
  \def\labelenumi{\theenumi.}
  \def\labelenumii{\theenumii.}
  \def\labelenumiii{\theenumiii.}
  \def\labelenumiv{\theenumiv.}
}{}
\makeatother

% ========== bm 包内存优化 ==========
% beamer 中 \boldsymbol 消耗大量内存，用 \mathbf 替代
\AtBeginDocument{
  \let\boldsymbol\mathbf
}

% 全角符号转换为半角符号
\usepackage{newunicodechar}
\newunicodechar{（}{(}
\newunicodechar{）}{)}

